---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Stack from '../components/Stack.astro';
import Writing from '../components/Writing.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout loader={true}>
  <span id="top"></span>
  <Nav />
  <main>
    <Hero />
    <About />
    <Experience />
    <Projects />
    <Stack />
    <Writing />
    <Contact />
  </main>
  <Footer />
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function revealHero() {
    if (prefersReduced) return;
    gsap.from(
      ['.site-nav', '.hero-eyebrow', '.hero-headline', '.hero-body', '.hero-ctas', '.hero-photo'],
      {
        opacity: 0,
        y: 16,
        duration: 0.6,
        ease: 'power2.out',
        stagger: 0.08,
      }
    );
  }

  function revealOnScroll(targets: gsap.TweenTarget, trigger: string) {
    if (prefersReduced) return;
    gsap.from(targets, {
      opacity: 0,
      y: 20,
      duration: 0.6,
      ease: 'power2.out',
      stagger: 0.07,
      scrollTrigger: {
        trigger,
        start: 'top 80%',
        once: true,
      },
    });
  }

  function initReveals() {
    revealOnScroll(['.about-headline', '.about-body', '.education-entry', '.glance-row'], '#about');
    revealOnScroll('.experience-entry', '#experience');
    revealOnScroll(['.projects-headline', '.project-row'], '#projects');
    revealOnScroll('.stack-item', '#stack');
    revealOnScroll(['.writing-headline', '.writing-row'], '#writing');
    revealOnScroll(['.contact-headline', '.contact-body', '.contact-link'], '#contact');
  }

  // Nav: solid background past the hero
  ScrollTrigger.create({
    start: 'top -80',
    onEnter: () => document.querySelector('nav')?.classList.add('scrolled'),
    onLeaveBack: () => document.querySelector('nav')?.classList.remove('scrolled'),
  });

  // Nav: active section highlight
  function setActiveNav(id: string) {
    document.querySelectorAll('.nav-link').forEach((link) => link.classList.remove('active'));
    document
      .querySelectorAll(`.nav-link[href="#${id}"]`)
      .forEach((link) => link.classList.add('active'));
  }

  ['about', 'experience', 'projects', 'stack', 'writing', 'contact'].forEach((id) => {
    ScrollTrigger.create({
      trigger: `#${id}`,
      start: 'top center',
      end: 'bottom center',
      onEnter: () => setActiveNav(id),
      onEnterBack: () => setActiveNav(id),
    });
  });

  initReveals();

  // Loading screen
  const loader = document.getElementById('loader');
  if (loader && !prefersReduced) {
    gsap
      .timeline({
        onComplete: () => {
          loader.style.display = 'none';
          revealHero();
        },
      })
      .to('#loader-name', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' })
      .to('#loader-bar', { width: '100%', duration: 1.0, ease: 'power1.inOut' }, '-=0.2')
      .to('#loader', { opacity: 0, duration: 0.4, ease: 'power2.in' }, '+=0.2');
  } else if (loader) {
    loader.style.display = 'none';
  }
</script>

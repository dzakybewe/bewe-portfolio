---
const groups = [
  { label: 'Mobile', items: ['Flutter', 'Dart', 'Kotlin', 'Jetpack Compose', 'BLoC', 'Provider', 'ObjectBox', 'Firebase'] },
  { label: 'Web', items: ['Next.js', 'Tailwind CSS', 'HTML', 'CSS', 'Laravel', 'next-intl'] },
  { label: 'Backend & Data', items: ['Supabase', 'Firebase', 'SQL', 'Python'] },
  { label: 'Tools', items: ['Git', 'Figma', 'Vercel', 'OneSignal', 'PostHog'] },
];

const items = groups.flatMap((g) => g.items.map((name) => ({ name, group: g.label })));
---

<section id="stack" class="w-full bg-cream-2 py-12 lg:py-20 overflow-hidden">
  <div class="max-w-container mx-auto px-7 lg:px-8 mb-8">
    <p class="eyebrow">Stack</p>
    <h2 class="stack-headline font-serif text-[26px] md:text-[28px] leading-[1.2] text-ink">
      Tools I reach for<br />
      when things need to <em class="italic text-accent">ship</em>.
    </h2>
  </div>

  <div class="stack-marquee" data-stack-marquee>
    <div class="stack-track" data-stack-track>
      {
        [...items, ...items].map((item, i) => (
          <div class="stack-item" aria-hidden={i >= items.length ? 'true' : undefined}>
            <span class="font-sans text-[13px] font-medium text-ink">{item.name}</span>
            <span class="font-sans text-[11px] uppercase tracking-[1.5px] text-ink-light mt-1">
              {item.group}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stack-marquee {
    width: 100%;
    overflow: hidden;
  }
  .stack-track {
    display: flex;
    width: max-content;
    gap: 1px;
    background: var(--color-rule);
    border-block: 0.5px solid var(--color-rule);
    will-change: transform;
  }
  .stack-item {
    display: flex;
    flex-direction: column;
    flex: 0 0 auto;
    width: 180px;
    background: var(--color-cream-2);
    padding: 20px 24px;
  }
  @media (prefers-reduced-motion: reduce) {
    .stack-track {
      transform: none !important;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  function initStackMarquee() {
    const track = document.querySelector<HTMLElement>('[data-stack-track]');
    const wrap = document.querySelector<HTMLElement>('[data-stack-marquee]');
    if (!track || !wrap) return;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    // Track holds two copies; one copy width = half the scrollWidth.
    const loopWidth = track.scrollWidth / 2;
    const speed = 40; // px per second — consistent regardless of content width
    const duration = loopWidth / speed;

    const tween = gsap.to(track, {
      x: -loopWidth,
      duration,
      ease: 'none',
      repeat: -1,
    });

    wrap.addEventListener('mouseenter', () => tween.pause());
    wrap.addEventListener('mouseleave', () => tween.resume());
  }

  initStackMarquee();
  document.addEventListener('astro:after-swap', initStackMarquee);
</script>

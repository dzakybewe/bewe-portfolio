---
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="projects" class="w-full bg-cream py-12 lg:py-20">
  <div class="max-w-container mx-auto px-7 lg:px-8">
    <p class="eyebrow">Projects</p>
    <h2 class="projects-headline font-serif text-[22px] md:text-[28px] leading-[1.2] text-ink mb-3">
      Things I've<br />
      built and <em class="italic text-accent">shipped</em>.
    </h2>
    <p class="projects-headline font-sans text-[10px] text-ink-light mb-6">
      Click any project to read the full case study.
    </p>

    <div>
      {
        projects.map((p) => (
          <a href={`/projects/${p.id}`} class="project-row">
            <div class="flex items-baseline gap-4 min-w-0">
              <span class="font-serif text-[13px] text-rule shrink-0">
                {String(p.data.order).padStart(2, '0')}
              </span>
              <div class="min-w-0">
                <h3 class="font-serif text-[16px] text-ink truncate">{p.data.title}</h3>
                <p class="font-sans text-[9px] text-ink-light mt-0.5">
                  {p.data.subtitle} · {p.data.period}
                </p>
              </div>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <div class="hidden sm:flex items-center gap-1.5">
                {p.data.tags.slice(0, 3).map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
              <span class="row-arrow" aria-hidden="true">↗</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .project-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 8px;
    margin: 0 -8px;
    border-bottom: 0.5px solid var(--color-rule);
    transition: background 0.2s ease;
  }
  .project-row:first-of-type {
    border-top: 0.5px solid var(--color-rule);
  }
  .project-row:hover {
    background: var(--color-cream-2);
  }
  .row-arrow {
    font-size: 14px;
    color: var(--color-rule);
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .project-row:hover .row-arrow {
    color: var(--color-accent);
    transform: translate(2px, -2px);
  }
</style>

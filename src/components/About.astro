---
const glance = [
  { label: "Based in", value: "Jakarta, Indonesia" },
  { label: "Degree", value: "Computer Science" },
  { label: "GPA", value: "3.76 / 4.00" },
  { label: "Primary stack", value: "Flutter · Next.js" },
  { label: "Languages", value: "Bahasa Indonesia · English" },
  { label: "Status", value: "Available immediately" },
];
---

<section id="about" class="w-full bg-cream py-12 lg:py-20">
  <div
    class="max-w-container mx-auto px-7 lg:px-8 grid grid-cols-1 md:grid-cols-[1.1fr_1fr] gap-10 md:gap-14"
  >
    <!-- Left: bio + education -->
    <div>
      <p class="eyebrow">About</p>
      <h2
        class="about-headline font-serif text-[26px] md:text-[28px] leading-[1.2] text-ink mb-3"
      >
        I care about what<br />
        gets built, and <em class="italic text-accent">why</em>.
      </h2>
      <p
        class="about-body font-sans text-[16px] font-light leading-[1.9] text-ink-mid max-w-[58ch] text-justify"
      >
        I'm a software developer with a focus on mobile, working mainly in
        Flutter, with Next.js for the web. I care most about the part before the
        code: understanding who's actually using the thing and what they
        actually need. <br /><br />
        Most recently, I worked as a Mobile Apps Developer Intern at PT Umma Bright
        Indonesia, where I maintained and improved a Flutter app used by 500+ weekly
        active users across iOS and Android, driving crash-free rates from 32% to
        85% on Android and 58% to 89% on iOS.
        <br /><br />
        Before that, I worked across mobile and web at PT Digdaya Olah Teknologi Indonesia
        (DOT Indonesia), and as a freelance developer delivering projects like a Point-of-Sale
        system for Sakera Kendari and a bilingual company website for PT Kartika Jasa
        Karya. I also worked with Kotlin during Bangkit Academy 2024 by Google, GoTo,
        and Traveloka, collaborating with Machine Learning and Cloud Computing teams.
        <br /><br />
        I'm a Computer Science graduate from Brawijaya University, currently based
        in Jakarta, looking for my next full-time role.
      </p>
    </div>

    <!-- Right: at a glance + education (two boxed cards) -->
    <div class="about-sidebar h-fit">
      <div class="about-card">
      <p class="section-label">At a glance</p>
      <dl>
        {
          glance.map((row, i) => (
            <div
              class:list={[
                "glance-row flex justify-between gap-4 py-3",
                { "border-t border-rule": i > 0 },
              ]}
            >
              <dt class="font-sans text-[13px] uppercase tracking-[1.5px] text-ink-light">
                {row.label}
              </dt>
              <dd class="font-sans text-[13px] text-ink text-right">
                {row.value}
              </dd>
            </div>
          ))
        }
      </dl>
      </div>

      <div class="about-card">
      <p class="section-label">Education</p>

      <div class="education-entry py-3">
        <h3 class="font-serif text-[16px] text-ink">Brawijaya University</h3>
        <p class="font-sans text-[13px] text-ink-mid mt-1">
          Bachelor of Computer Science
        </p>
        <p class="font-sans text-[13px] text-ink-light mt-1">
          Aug 2021 – Jul 2025 · GPA 3.76 / 4.00
        </p>
        <p
          class="font-sans text-[13px] font-light leading-[1.7] text-ink-light mt-2 max-w-[60ch]"
        >
          Thesis: Sentiment Analysis of MyPertamina App User Reviews on Google
          Play Store Using XGBoost and Word2Vec Embedding Methods.
        </p>
      </div>

      <div class="education-entry py-3 border-t border-rule">
        <h3 class="font-serif text-[16px] text-ink">
          Bangkit Academy 2024 — by Google, GoTo, Traveloka
        </h3>
        <p class="font-sans text-[13px] text-ink-mid mt-1">
          Android Learning Path
        </p>
        <p class="font-sans text-[13px] text-ink-light mt-1">Feb – Jun 2024</p>
        <p
          class="font-sans text-[13px] font-light leading-[1.7] text-ink-light mt-2 max-w-[60ch]"
        >
          Built BiteWise, a personalized restaurant recommendation app,
          collaborating with ML and Cloud teams
        </p>
      </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Sidebar holds two separate cards with a gap between them. */
  .about-sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  /* Boxed cards — set the At a Glance + Education column apart from the
     plain bio prose on the left. */
  .about-card {
    background: var(--color-cream-2);
    border: 0.5px solid var(--color-rule);
    border-radius: 2px;
    padding: 28px;
  }
  @media (min-width: 1024px) {
    .about-card {
      padding: 32px;
    }
  }
</style>

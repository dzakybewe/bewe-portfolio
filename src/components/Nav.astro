---
interface Props {
  /** Homepage uses transparent-over-hero nav with in-page anchors.
      Inner pages force the solid "scrolled" look and link back to /#section. */
  home?: boolean;
}

const { home = true } = Astro.props;

const links = [
  { label: 'About', id: 'about' },
  { label: 'Experience', id: 'experience' },
  { label: 'Projects', id: 'projects' },
  { label: 'Stack', id: 'stack' },
  { label: 'Writing', id: 'writing' },
  { label: 'Contact', id: 'contact' },
];

const hrefFor = (id: string) => (home ? `#${id}` : `/#${id}`);
---

<nav class:list={['site-nav', { 'scrolled solid': !home }]} aria-label="Primary">
  <div class="max-w-container mx-auto px-7 lg:px-8 flex items-center justify-between h-full">
    <!-- TODO: Replace text logo with <img src="/logo.svg" alt="Dzaky Ahmadin" /> when logo asset is ready. Place logo file at public/logo.svg -->
    <a href={home ? '#top' : '/'} class="font-serif text-[15px] md:text-[15px] text-ink leading-none">
      Dzaky Ahmadin
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-7">
      {
        links.map((link) => (
          <li>
            <a
              href={hrefFor(link.id)}
              class="nav-link font-sans text-[9px] uppercase tracking-[2px] text-ink-light"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile toggle -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col justify-center gap-[5px] w-7 h-7"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span class="block h-[1.5px] w-6 bg-ink transition-all"></span>
      <span class="block h-[1.5px] w-6 bg-ink transition-all"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="nav-mobile" class="md:hidden hidden border-t border-rule bg-cream/95 backdrop-blur">
    <ul class="max-w-container mx-auto px-7 py-4 flex flex-col gap-4">
      {
        links.map((link) => (
          <li>
            <a
              href={hrefFor(link.id)}
              class="nav-link block font-sans text-[10px] uppercase tracking-[2px] text-ink-light"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 64px;
    background: transparent;
    border-bottom: 0.5px solid transparent;
    transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
  }
  .site-nav.scrolled {
    background: rgba(253, 251, 246, 0.88);
    backdrop-filter: blur(8px);
    border-bottom: 0.5px solid var(--color-rule);
  }
  /* When the mobile menu is open the bar needs a solid backdrop too. */
  .site-nav.menu-open {
    background: rgba(253, 251, 246, 0.95);
    backdrop-filter: blur(8px);
  }

  .nav-link {
    position: relative;
    padding-bottom: 2px;
    border-bottom: 0.5px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .nav-link:hover {
    color: var(--color-accent);
  }
  .nav-link.active {
    color: var(--color-accent);
    border-bottom: 0.5px solid var(--color-accent);
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-mobile');
  const nav = document.querySelector('.site-nav');

  function closeMenu() {
    menu?.classList.add('hidden');
    nav?.classList.remove('menu-open');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    nav?.classList.toggle('menu-open', !isHidden);
    toggle.setAttribute('aria-expanded', String(!isHidden));
  });

  // Close after tapping a link
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
</script>
